---
import Navbar from '@components/Navbar.astro';
import Layout from '../../layouts/BaseLayout.astro';
import { GetFlights } from '@libs/flying';
import type { Flight } from '@libs/flyingTypes';
import FlyCalendar from '@components/flying/FlyCalendar';
import prettyMs from 'pretty-ms';
import '@fontsource/capriola/latin-400.css';
import FlightGraphs from '@components/flying/FlightsGraphs';
import FlightCardList from '@components/flying/FlightCardList';

export type Props = {
  flights?: Flight[];
  headingPostfix?: string;
};

// Get filtered flights, or get directly from disk
let { flights, headingPostfix } = Astro.props;
if (!flights) {
  flights = await GetFlights();
}

const flightCount = flights.length;
const totalSeconds = flights.reduce((a, b) => a + (b.durationSeconds ?? 0), 0);
const totalHours = totalSeconds / 60.0 / 60.0;
const totalTime = prettyMs(totalSeconds * 1000, {
  verbose: true,
  hideSeconds: true,
});

const showHero = headingPostfix === undefined;

// Calculate total Ridge vs Thermal hours
const ridgeHours = flights.reduce(
  (a, b) => a + (b.type === 'ridge' ? b.durationSeconds ?? 0 : 0),
  0
) / 60.0 / 60.0;
const thermalHours = flights.reduce(
  (a, b) => a + (b.type === 'thermal' ? b.durationSeconds ?? 0 : 0),
  0
) / 60.0 / 60.0;

const statClassStyles = 'font-bold text-sm font-[capriola] italic';
const metricClassStyles = 'text-orange-500 text-2xl not-italic';
---

<Layout title="Flying Log" description="Paragliding Flying Logbook">
  <div
    class="flyingpage-layout-container overflow-y-scroll overflow-x-hidden h-lvh w-full bg-[#fefefe] text-[#444]"
    style="scroll-padding-block-start: 200px;"
  >
    <!-- Hero Image -->
    {showHero && (
    <div id="hero-container" class="hero-video hero-video--cover relative w-full h-[75vh] overflow-hidden snap-start">
      <!-- Blurred background (shown in square mode) -->
      <canvas id="hero-blur-bg" class="hero-video__blur" aria-hidden="true"></canvas>
      <!-- Main video -->
      <video
        id="hero-video"
        src="/ParaglidingHeader.mp4"
        class="hero-video__main"
        autoplay
        loop
        muted
        playsinline></video>
      <!-- Mode toggle -->
      <button
        id="hero-toggle"
        class="absolute bottom-3 right-3 z-20 bg-black/40 hover:bg-black/60 text-white rounded-md p-1.5 transition-colors"
        title="Toggle video display mode"
      >
        <!-- Shown in rect mode: click to go square -->
        <svg id="icon-to-square" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
        </svg>
        <!-- Shown in square mode: click to go rect -->
        <svg id="icon-to-rect" class="hero-toggle__icon--hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="6" width="20" height="12" rx="2"/>
        </svg>
      </button>
    </div>
    )}

    <header class="w-full m-0 pt-0 snap-start" style="">
      <div class="flex flex-grow flex-wrap items-center justify-center" }>
        <!-- Flight Stats -->
        <div
          class={statClassStyles + ' self-end text-center order-2 md:order-1'}
        >
          <div>
            <span class={metricClassStyles}>{flightCount}</span> Flights
          </div>
          <div>
            <span class={metricClassStyles + ' pl-10'}
              >{Math.round(totalHours)}</span
            > Hours
          </div>
          <div class="text-xs m-2 text-gray-300">
            (or <span class="text-orange-300">{totalTime}</span>)
          </div>
          <div>
            <div><span class={metricClassStyles}>{Math.round(thermalHours)}</span> hrs <a href="/flying/type/thermal" class="text-orange-500 underline">Thermal</a></div>
            <div><span class={metricClassStyles}>{Math.round(ridgeHours)}</span> hrs <a href="/flying/type/ridge" class="text-orange-500 underline">Ridge</a></div>
          </div>
        </div>

        <!-- Header Middle / Nav -->
        <div
          class="header-middle text-center min-w-full md:order-2 md:min-w-[490px]"
        >
          <h1 class="text-2xl text-center mb-0">
            <a href="/flying/">Paragliding Logbook </a>{headingPostfix}
          </h1>
          <div class="mb-4 italic text-sm text-orange-300 underline pl-20">
            <a href="/post/2025-06-09-paragliding-logbook/">How this site is made</a>
          </div>
          <Navbar />
        </div>

        <!-- Badges to go here -->
        <div class="order-3 md:order-3"></div>
      </div>
    </header>

    <main class="w-full text-center">
      <div class="min-h-[212px] mt-4 lg:hidden">
        <FlyCalendar client:only="react" flights={flights} />
      </div>

      <div class="flex flex-wrap lg:mt-16">
        <!-- Flights left hand bar (wide displays) -->
        <div class="w-[200px] min-h-[650px] hidden lg:block">
          <FlyCalendar client:only="react" flights={flights} verticle />
        </div>
        <div class="grow lg:border-l lg:pl-2">
          <div class="min-h-[550px]">
            <FlightGraphs client:only="react" flights={flights} height={550} />
          </div>
          <div class="m-4">
            <FlightCardList
              client:only="react"
              flights={flights}
              itemsPerPage={5}
            >
              <div slot="fallback" class="animate-pulse min-h-30 m-auto">
                Loading...
              </div>
            </FlightCardList>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  const heroContainer = document.getElementById('hero-container');
  if (heroContainer) {
  const container = heroContainer as HTMLElement;
  const blurCanvas = document.getElementById('hero-blur-bg') as HTMLCanvasElement;
  const ctx = blurCanvas.getContext('2d');
  const mainVideo = document.getElementById('hero-video') as HTMLVideoElement;
  const iconToSquare = document.getElementById('icon-to-square') as HTMLElement;
  const iconToRect = document.getElementById('icon-to-rect') as HTMLElement;

  let containMode = false;
  let userMode: boolean | undefined;

  function setMode(contain: boolean) {
    containMode = contain;
    container.classList.toggle('hero-video--contain', contain);
    container.classList.toggle('hero-video--cover', !contain);
    iconToSquare.classList.toggle('hero-toggle__icon--hidden', contain);
    iconToRect.classList.toggle('hero-toggle__icon--hidden', !contain);
  }

  function applyAutoMode() {
    if (!mainVideo.videoWidth || !mainVideo.videoHeight) return;
    if (userMode !== undefined) {
      setMode(userMode);
      return;
    }

    const videoAspect = mainVideo.videoWidth / mainVideo.videoHeight;
    const heroAspect = container.clientWidth / container.clientHeight;
    setMode(heroAspect > 2 * videoAspect);
  }

  function resizeCanvas() {
    blurCanvas.width = container.clientWidth;
    blurCanvas.height = container.clientHeight;
  }

  document.getElementById('hero-toggle')!.addEventListener('click', () => {
    userMode = !containMode;
    setMode(userMode);
  });

  const resizeObserver = new ResizeObserver(() => {
    applyAutoMode();
    resizeCanvas();
  });
  resizeObserver.observe(container);

  mainVideo.addEventListener('loadedmetadata', applyAutoMode);

  // Canvas-based blur: draw frames from the main video via rAF.
  // Stops when hero is offscreen so Safari doesn't do needless GPU work.
  let rafId: number | null = null;

  function startDrawing() {
    if (rafId !== null) return;
    function loop() {
      if (ctx && containMode && mainVideo.readyState >= 2) {
        ctx.drawImage(mainVideo, 0, 0, blurCanvas.width, blurCanvas.height);
      }
      rafId = requestAnimationFrame(loop);
    }
    rafId = requestAnimationFrame(loop);
  }

  function stopDrawing() {
    if (rafId !== null) {
      cancelAnimationFrame(rafId);
      rafId = null;
    }
  }

  new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        startDrawing();
      } else {
        stopDrawing();
      }
    },
    { threshold: 0.01 }
  ).observe(container);

  resizeCanvas();
  startDrawing();
  } // end if (heroContainer)
</script>

<style is:global>
  .hero-video__blur,
  .hero-video__main {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-video__blur {
    transform: scale(1.1);
    filter: blur(24px);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .hero-video__main {
    z-index: 10;
    object-fit: cover;
  }

  .hero-video--contain .hero-video__blur {
    opacity: 0.75;
  }

  .hero-video--contain .hero-video__main {
    object-fit: contain;
  }

  .hero-video--cover .hero-video__main {
    object-fit: cover;
  }

  .hero-toggle__icon--hidden {
    display: none;
  }

  .slick-slider {
    /* height: 100%; */
  }

  .slider-container {
    /* aspect-ratio: 5.5 / 1; */
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    scroll-snap-align: start;
  }

  * {
    min-height: 0;
    min-width: 0;
  }

  main a {
    @apply font-bold text-orange-600;
  }

  [data-testid="backdrop"] {
    z-index: 9999;
  }
</style>
